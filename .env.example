# Google Cloud OAuth 2.0 Desktop client credentials
# 1. Google Cloud Console -> APIs & Services -> Credentials -> Create OAuth client ID -> Desktop app
# 2. YouTube Data API v3 must be enabled in the same project
# 3. Copy Client ID / Client secret here, then run setup-oauth.ps1 once to fill REFRESH_TOKEN

CLIENT_ID=
CLIENT_SECRET=
REFRESH_TOKEN=

# Optional: override the window-title pattern used by Find-HtsWindow.
# Useful when 영웅문 changes its title or when running smoke-test against Notepad.
WINDOW_TITLE_OVERRIDE=
